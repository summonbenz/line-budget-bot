# โดเมนที่ชี้ DNS A record มาที่ IP ของ droplet แล้ว (Chiyu จะขอ TLS cert ให้อัตโนมัติ)
DOMAIN=example.com

# ซับโดเมนแยกต่างหากสำหรับหน้าเว็บ Actual Budget (ต้องชี้ DNS A record มาที่ IP เดียวกันด้วย)
# แยกโดเมนเพราะ Actual serve asset ด้วย absolute path ที่ proxy เป็น path prefix ใต้ DOMAIN ไม่ได้
ACTUAL_DOMAIN=actual.example.com

# Line Developers Console > Messaging API channel
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Google Cloud Console > APIs & Services > Credentials (เปิดใช้ Vision API ก่อน)
GOOGLE_VISION_API_KEY=

# Google AI Studio (aistudio.google.com/apikey) — ใช้ให้ Gemini อ่านสลิป/statement เป็น JSON
# สร้างในโปรเจกต์ที่ไม่มี billing เพื่อเข้า free tier (ห้ามใช้ GOOGLE_VISION_API_KEY แทน)
GEMINI_API_KEY=
# เปลี่ยนรุ่นได้ (ไม่ตั้งก็ใช้ gemini-flash-lite-latest)
# GEMINI_MODEL=gemini-flash-lite-latest

# รหัสผ่าน PDF statement ต่อธนาคาร เป็น JSON — key ต้องตรงกับปุ่มเลือกธนาคารในบอท
# (kbank/scb/bbl/ktb/ttb/krungsri/uob/kkp/gsb) ธนาคารที่ไม่ใส่ถือว่า PDF ไม่ติดรหัส
# ตัวอย่าง: PDF_PASSWORDS={"kbank":"1234","scb":"0987"}
PDF_PASSWORDS=
# ค่าเริ่มต้น: render 150 dpi, อ่านสูงสุด 15 หน้าแรก (ปรับได้ถ้า statement ยาว/ต้องการคมขึ้น)
# PDF_RENDER_DPI=150
# PDF_MAX_PAGES=15

# URL รูปจิยุ (https สาธารณะ) มุมหัวการ์ด "นำเข้าสำเร็จ" — ไม่ตั้งก็ได้ แค่ไม่มีรูป
# CHIYU_HERO_URL=https://example.com/chiyu-hero.png

# ตั้งรหัสผ่านนี้เองตอน docker compose up ครั้งแรก (ใช้ล็อกอินหน้าเว็บ Actual)
ACTUAL_SERVER_PASSWORD=

# ได้มาหลังสร้าง budget ใหม่ในหน้าเว็บ Actual ครั้งแรก (Settings > Show advanced settings > Sync ID)
ACTUAL_SYNC_ID=

# Line Developers Console > channel ที่ใช้สร้าง LIFF app (มักเป็นคนละ channel id กับ Messaging API)
LIFF_CHANNEL_ID=

# LIFF ID เต็ม เช่น 1234567890-abcdefgh (ค่าเดียวกับ VITE_LIFF_ID ฝั่ง liff-web)
# ใช้ประกอบลิงก์ปุ่ม "แก้ไขรายการ" แบบ liff.line.me/{LIFF_ID}/edit/{id}
# เพื่อให้เปิดใน LIFF browser — เปิดเป็น https ตรงๆ จะได้ in-app browser ที่ liff.closeWindow() ใช้ไม่ได้
LIFF_ID=

# Line user id ของเจ้าของบอทคนเดียว (ดูได้จาก log หลังทักบอทครั้งแรก: docker compose logs line-bot | grep line_user_id)
ALLOWED_LINE_USER_ID=
