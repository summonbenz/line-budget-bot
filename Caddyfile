{$DOMAIN} {
	encode gzip

	# Line webhook - จุดเดียวที่ Line จะยิงมา
	handle /webhook* {
		reverse_proxy line-bot:3000
	}

	# API สำหรับ LIFF dashboard - ตรวจ auth เองอยู่แล้วใน line-bot (bot/src/auth.js)
	handle /api/* {
		reverse_proxy line-bot:3000
	}

	# LIFF web dashboard - static site, เปิดจากในแอป Line ผ่าน liff.line.me/{liffId}
	# try_files: เส้นทางที่ไม่ใช่ไฟล์จริง (เช่น /app/edit/{id}) ให้ตกไป index.html แบบ SPA
	handle /app/* {
		uri strip_prefix /app
		root * /srv/liff-web
		try_files {path} /index.html
		file_server
	}

	handle {
		respond "ok" 200
	}
}

# หน้าเว็บ Actual Budget อยู่คนละ (sub)domain แยกต่างหาก ไม่ใช่ path prefix
# เพราะ Actual serve asset ด้วย absolute path (/static/js/...) ที่ hardcode ไว้ที่ root
# เลย proxy เป็น path prefix ใต้โดเมนหลักไม่ได้ ต้องแยกโดเมน/ซับโดเมนเท่านั้น
{$ACTUAL_DOMAIN} {
	# ควรใส่ basicauth ป้องกันไว้ด้วย เพราะเป็นข้อมูลการเงิน (แนะนำให้เปิดใช้จริง):
	# basicauth {
	# 	admin JDJhJDE0JGV4YW1wbGVoYXNoZXhhbXBsZQ==
	# }
	# สร้าง hash ด้วยคำสั่ง: docker run --rm caddy caddy hash-password --plaintext 'your-password'
	reverse_proxy actual-server:5006
}
